# Database (Neon, Frankfurt region)
DATABASE_URL=

# Auth ; for auth secret, generate your own key via openssl rand -hex 32
AUTH_SECRET=
MAGIC_LINK_TTL_MINUTES=15
SESSION_TTL_DAYS=7

# Email (Brevo transactional API — https://app.brevo.com/settings/keys/api)
# Sender is hardcoded in src/lib/email.ts (verified domain feedmyfrog.click).
BREVO_API_KEY=

# Application
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_INSTITUTION_DOMAIN=reutlingen-university.de
ALLOWED_EMAIL_DOMAIN=reutlingen-university.de

# Rate limits (per hour, per dimension)
RATE_LIMIT_SEND_LINK_PER_IP=10
RATE_LIMIT_SEND_LINK_PER_EMAIL=5
